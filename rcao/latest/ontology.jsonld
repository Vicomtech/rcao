    "@value" : "https://www.vicomtech.org/en, (https://ror.org/0023sah13)"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "Resilient Collective Awareness Ontology"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "rcao"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@value" : "https://www.w3id.org/rcao#"
  } ],
  "http://schema.org/citation" : [ {
    "@value" : "Cite this ontology as: Utrilla Guerrero, C., Aranjuelo Ansa, N., and Nieto Doncel, M., (2026). Resilient Collective Awareness Ontology 0.1.0. https://w3id.org/rcao/0.1.0"
  } ],
  "http://schema.org/logo" : [ {
    "@value" : "https://raw.githubusercontent.com/Vicomtech/rcao/main/rcao/sections/media/rcao-logo.png"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The RCAO aims to provide a common knowledge model of the resilient collective awareness on automated driving domain."
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#"
  }, {
    "@id" : "http://www.w3.org/ns/prov-o#"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://w3id.org/rcao/0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.1.0"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#Algorithm",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the fusion logic agent that consumes input states and produces fused state."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Agent"
  }, {
    "@id" : "https://www.w3id.org/rcao#InformationSource"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#AmbientCondition",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents environmental factors that affect driving including wather as rain, snow, fog, sun or lighting day, dark, gare or roadSurfaceCondition e.g., wet, icy,debris."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Context"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#AutomatedDrivingSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the Automated Driving System itself."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Agent"
  }, {
    "@id" : "https://www.w3id.org/rcao#TrafficParticipant"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#AwarenessState",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the status of awareness relationship, describing a specific subject's awareness of a specific object at a point in time, characterized by resilience attributes."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2002/07/owl#Thing"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#BroadcastActivity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The specific activity of encoding and transmitting awareness states via V2X messages (CPM, DENM) to other agents."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#Completeness",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the degree of completion of the information."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#ComprehensionAwareness",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Level 2: Represents a synthetised understanding of the meaning or significance of perceived information. An instance of this class is typically derived from one or more PerceptualAwareness states. For example, from perceiving a vehicle's position and its brake light status, a Level 2 state can be inferred: 'Subject S is aware that the vehicle ahead is braking hard, constituting a potential hazard'."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://www.w3id.org/rcao#PerceptualAwareness"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#ComprehensionProcess",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The activity of synthesizing multiple PerceptualAwareness states and Context to infer meaning or risk (ComprehensionAwareness). Represents the 'Understanding' phase."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#ConnectedVehicle",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents other vehicles equpped with V2x technology, whose state can be inferred from broadcast messages."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/rcao#TrafficParticipant"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#Driver",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the human operator whose awareness is critical for safe takovers."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Human"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#FusionProcess",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A specific process that aggregates multiple AwarenessStates into a single intermediate fused state (PA_Fused)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#GenderBias",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents the bias with regards to gender of a model. A model is gender biased if the model's performance and/or output is biased against a faction of population based on their gender."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://www.w3id.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#InformationSource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents a source of data or information from which an AwarenessState is derived from different sources, enabling traceability and trust assessment. Represents the hardware or service generating data (e.g., sensor:Lidar, v2x:RSU_1)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#InfrastructureElement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents intelligent roadside infrastructure such as Roadside Units (RSUs) and smart traffic signals via SPaT, MAP and CPM messages."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Infrastructure"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#ODD_MonitoringProcess",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The activity of monitoring the Operational Design Domain (ODD) limits to trigger fallbacks if boundaries are exceeded (Scenario 7)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "https://www.w3id.org/rcao#PerceptionProcess",
