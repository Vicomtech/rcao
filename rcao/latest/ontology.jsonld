  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents regulatory objects like TrafficSign, TrafficSignal and RoadMarking."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Infrastructure"
  } ]
}, {
  "@id" : "http://vcd.vicomtech.org/ontology/automotive#TrafficSign",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Represents static displays that provide rules, warnings, or directions, while traffic signals are illuminated devices that control traffic flow using colored lights."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement"
  } ]
}, {
  "@id" : "http://vcd.vicomtech.org/ontology/automotive#TrafficSignal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : " Represent active and electronic devices that control vehicle and pedestrian movement at intersections, using colored lights to indicate when to stop or go."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement"
  } ]
