@prefix schema: <http://schema.org/> .
@base <https://www.w3id.org/rcao> .

<https://www.w3id.org/rcao> rdf:type owl:Ontology ;
    owl:versionIRI <https://w3id.org/rcao/0.1.0> ;
    
    # 1. Creadores (IRIs puros)
    dc:creator "Carlos Utrilla Guerrero, Vicomtech (0000-0002-9994-1462)",
                "Nerea Aranjuelo Ansa, Vicomtech (0000-0001-9879-0992)",
                "Marcos Nieto Doncel (0000-0002-7853-6708)";
                                              
    # 2. NUEVO: Contribuidores (Puede usar literales de texto o IRIs ORCID si lo prefiere)
    dc:contributor "New collaborator ()",
                    "other ()";                                                  
    dc:title "Resilience Collective Awareness Ontology" ;
    dc:created "2026-04-25T12:00:00"^^xsd:dateTime ;
    dc:issued "2026-04-25T12:00:00"^^xsd:dateTime ;
    dc:license "https://creativecommons.org/licenses/by/4.0/" ;
    dc:publisher "https://www.vicomtech.org/en, (https://ror.org/0023sah13)" ;
    vann:preferredNamespacePrefix "rcao" ;    
    # 3. CORRECCIÓN VANN: Añadimos www. y el # al final para el parser de Ontospy
    vann:preferredNamespaceUri "https://www.w3id.org/rcao#" ;
    
    schema:citation "Cite this ontology as: Utrilla Guerrero, C., Aranjuelo Ansa, N., and Nieto Doncel, M., (2025). Resilience Collective Awareness Ontology 0.1.0. https://w3id.org/rcao/0.1.0" ;
    rdfs:comment """The RCAO aims to provide a common knowledge model of the resilient collective awareness on automated driving domain."""@en ;
    owl:versionInfo "0.1.0" ;
    schema:logo "https://raw.githubusercontent.com/X.png" ;
    owl:imports <http://vcd.vicomtech.org/ontology/automotive#> , 
                <http://www.w3.org/ns/prov-o#> .


