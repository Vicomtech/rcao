#################################################################
#    HIERARCHY 1: TRAFFIC PARTICIPANTS (Who)
#################################################################

### SUPER: ago:Object (Imported)

### TOP: Traffic_Participants
rcao:TrafficParticipant rdf:type owl:Class ;
    rdfs:subClassOf ago:Object ;
    rdfs:comment "Represents anything tangible in the environment." .

### MID: AutomatedDrivingSystem
rcao:AutomatedDrivingSystem rdf:type owl:Class ;
    rdfs:subClassOf rcao:TrafficParticipant , prov:Agent ;
    rdfs:comment "Represents the Automated Driving System itself." .

### MID: HumanAgent (Implemented as ago:Human)
ago:Human rdf:type owl:Class ;
    rdfs:subClassOf rcao:TrafficParticipant , prov:Agent ;
    rdfs:comment "Represents the human occupant of a vehicle." .

### MID: ConnectedVehicle
rcao:ConnectedVehicle rdf:type owl:Class ;
    rdfs:subClassOf rcao:TrafficParticipant ;
    rdfs:comment "Represents other vehicles equpped with V2x technology, whose state can be inferred from broadcast messages." .

### BOTTOM: Driver
rcao:Driver rdf:type owl:Class ;
    rdfs:subClassOf ago:Human ;
    rdfs:comment "Represents the human operator whose awareness is critical for safe takovers." .

### BOTTOM: VulnerableRoadUser
rcao:VulnerableRoadUser rdf:type owl:Class ;
    rdfs:subClassOf ago:Human ;
    rdfs:comment "Represents any single real-world entitity as pederastian, cyclist, and other non-motorized road users." .

#################################################################
#    HIERARCHY 2: INFRASTRUCTURE (Where)
#################################################################

### TOP: Infrastructure
ago:Infrastructure rdf:type owl:Class ;
    rdfs:subClassOf ago:Object ;
    rdfs:comment "Represents the static and intelligent elements of the road environment." .

### MID: InfrastructureElement (Intelligent)
rcao:InfrastructureElement rdf:type owl:Class ;
    rdfs:subClassOf ago:Infrastructure ;
    rdfs:comment "Represents intelligent roadside infrastructure such as Roadside Units (RSUs) and smart traffic signals via SPaT, MAP and CPM messages." .

### MID: TrafficControlElement (Regulatory)
ago:TrafficControlElement rdf:type owl:Class ;
    rdfs:subClassOf ago:Infrastructure ;
    rdfs:comment "Represents regulatory objects like TrafficSign, TrafficSignal and RoadMarking." .

### BOTTOM: Specific Elements
rcao:RoadSideUnit rdf:type owl:Class ;
    rdfs:subClassOf rcao:InfrastructureElement , prov:Agent ;
    rdfs:comment "Represents intelligent roadside infrastructure capable of V2X communication." .

ago:TrafficSign rdf:type owl:Class ;
    rdfs:subClassOf ago:TrafficControlElement ;
    rdfs:comment "Represents static displays that provide rules, warnings, or directions, while traffic signals are illuminated devices that control traffic flow using colored lights." .

ago:TrafficSignal rdf:type owl:Class ;
    rdfs:subClassOf ago:TrafficControlElement ;
    rdfs:comment " Represent active and electronic devices that control vehicle and pedestrian movement at intersections, using colored lights to indicate when to stop or go." .

ago:RoadMarking rdf:type owl:Class ;
    rdfs:subClassOf ago:TrafficControlElement ;
    rdfs:comment "Represents the painted indications on the road surface." .

#################################################################
#    HIERARCHY 3: EPISTEMIC or AWARENESS STATES (What)
#################################################################

### TOP: AwarenessState
rcao:AwarenessState rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:comment "Represents the status of awareness relationship, describing a specific subject's awareness of a specific object at a point in time, characterized by resilience attributes." .

### MID: PerceptualAwareness (Level 1)
rcao:PerceptualAwareness rdf:type owl:Class ;
    rdfs:subClassOf rcao:AwarenessState ;
    owl:disjointWith rcao:ComprehensionAwareness ;
    rdfs:comment "Level 1: Represents the direct, uninterpreted perception of an object and its attributes. An instance of this class would assert, for example, 'Subject S is aware of Object O at position (x, y, z) with velocity V." .

### MID: ComprehensionAwareness (Level 2)
rcao:ComprehensionAwareness rdf:type owl:Class ;
    rdfs:subClassOf rcao:AwarenessState ;
    rdfs:comment "Level 2: Represents a synthetised understanding of the meaning or significance of perceived information. An instance of this class is typically derived from one or more PerceptualAwareness states. For example, from perceiving a vehicle's position and its brake light status, a Level 2 state can be inferred: 'Subject S is aware that the vehicle ahead is braking hard, constituting a potential hazard'." .

### MID: ProjectionAwareness (Level 3)
rcao:ProjectionAwareness rdf:type owl:Class ;
    rdfs:subClassOf rcao:AwarenessState ;
    rdfs:comment "Level 3:Represents a prediction about the future state of an object or situation derived from Level 2. Subject S is aware that the vehicle ahead is predicted to come to a complete stop in 1.5 seconds at position (x', y', z')." .

#################################################################
#    HIERARCHY 4: SOURCES & ALGORITHMS (How)
#################################################################

### TOP: InformationSource
rcao:InformationSource rdf:type owl:Class ;
    rdfs:subClassOf prov:Entity ; 
    rdfs:comment "Represents a source of data or information from which an AwarenessState is derived from different sources, enabling traceability and trust assessment. Represents the hardware or service generating data (e.g., sensor:Lidar, v2x:RSU_1)." .

### TOP: Algorithm (Logic Agent)
rcao:Algorithm rdf:type owl:Class ;
    rdfs:subClassOf prov:Agent , rcao:InformationSource ; 
    rdfs:comment "Represents the fusion logic agent that consumes input states and produces fused state." .

rcao:V2XMessage rdf:type owl:Class ;
    rdfs:subClassOf rcao:InformationSource ;
    rdfs:comment "Represent the data package intelligent road infrastructure emits." .

#################################################################
#    HIERARCHY 5: RESILIENCE (Trust)
#################################################################

### TOP: ResilienceAttribute
rcao:ResilienceAttribute rdf:type owl:Class ;
    rdfs:subClassOf owl:Thing ;
    rdfs:comment "Represents a quantificable or qualitative attribute describing the robustness, quality, or trustworthiness of an AwarnessState or InformationSoruce." .

### MID: Specific Attributes
rcao:TrustScore rdf:type owl:Class ;
    rdfs:subClassOf rcao:ResilienceAttribute ;
    rdfs:comment "Represents the degree of confidence and trust of the information." .

rcao:Completeness rdf:type owl:Class ;
    rdfs:subClassOf rcao:ResilienceAttribute ;
    rdfs:comment "Represents the degree of completion of the information." .

rcao:PositionalAccuracy rdf:type owl:Class ;
    rdfs:subClassOf rcao:ResilienceAttribute ;
    rdfs:comment "Represents the uncertain in an object´s location as covariance matrix." .

rcao:TemporalFreshness rdf:type owl:Class ;
    rdfs:subClassOf rcao:ResilienceAttribute ;
    rdfs:comment "Represents the age of the information." .

rcao:GenderBias rdf:type owl:Class ;
                rdfs:subClassOf rcao:ResilienceAttribute ;
                rdfs:comment "Represents the bias with regards to gender of a model. A model is gender biased if the model's performance and/or output is biased against a faction of population based on their gender." .


#################################################################
#    HIERARCHY 6: ACTIONS & CONTEXT
#################################################################

### rcao:runsProcess (Unified)
rcao:runsProcess rdf:type owl:ObjectProperty ;
    # ELIMINAR ESTA LÍNEA: rdfs:subPropertyOf prov:wasAssociatedWith ;
    owl:inverseOf prov:wasAssociatedWith ;
    
    # DOMINIO: Cualquier Agente (Humano, ADS, RSU, o Algoritmo/Cerebro)
    rdfs:domain prov:Agent ;
    
    # RANGO: Unión de procesos computacionales y acciones físicas
    rdfs:range [ rdf:type owl:Class ;
                 owl:unionOf ( prov:Activity ago:Action ) ] ;
                 
    rdfs:comment "Associate Agents (Humans or machines) with the process or action to be undertaken." .

### Context: Risk
rcao:Risk rdf:type owl:Class ;
    rdfs:subClassOf ago:Context ;
    rdfs:comment "Represents a formalised assessment of potential dangerous." .

### Context: AmbientCondition
rcao:AmbientCondition rdf:type owl:Class ;
    rdfs:subClassOf ago:Context ;
    rdfs:comment "Represents environmental factors that affect driving including wather as rain, snow, fog, sun or lighting day, dark, gare or roadSurfaceCondition e.g., wet, icy,debris." .

#################################################################
#    2. RELATIONS (from relations sheet)
#################################################################

### 2.1 Awareness Relationships

# [Source 1] Links a subject (agent) to a state of awareness it possesses.
rcao:hasAwarenessState rdf:type owl:ObjectProperty ;
    rdfs:domain ago:Object ;
    rdfs:range rcao:AwarenessState ;
    owl:inverseOf rcao:hasSubject ;
    rdfs:comment "Links a subject to a state of awareness it possesses." .

# [Source 1] Connects who is aware of what.
rcao:hasSubject rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range ago:Object ; # "any subject with awareness capacity"
    rdfs:comment "Connects who is aware of what. Identify the Subject (e.g., any instance of prov:Agent that is linked to an rcao:AwarenessState via the rcao:hasSubject property)." .

# [Source 1] Links awareness state to the entity it is about.
# Groups inputs for fusion queries (isAwarenessOf Pedestrian_456).
rcao:isAwarenessOf rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range owl:Thing ; # "owl:Thing(any of its subclasses ago:Action, ago:Context)"
    rdfs:comment "Links an awareness state to the entity it is about." .

# [Source 2] Connect what is being awaren (detected object).
rcao:hasObject rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    # ACTUALIZACION: Rango ampliado para soportar Meta-Consciencia
    rdfs:range [ rdf:type owl:Class ;
                 owl:unionOf ( ago:Object ago:Action ago:Context rcao:AwarenessState ) ] ;
    rdfs:comment "Connects what is being aware of." .

# [Source 3] Establishes the linking of the levels of awareness.
rcao:informs rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range rcao:ComprehensionAwareness ;
    rdfs:comment "Establishes the flow from lower levels to Comprehension." .

### 2.2 Provenance & Source Relations

### http://www.example.org/rcao#derivedFrom
rcao:derivedFrom rdf:type owl:ObjectProperty ;
    # CORRECTION: Remove 'rdfs:subPropertyOf prov:wasDerivedFrom ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range [ rdf:type owl:Class ;
                 owl:unionOf ( rcao:InformationSource rcao:AwarenessState )
               ] ;
    rdfs:comment "Links an awareness state to the source or previous state from which it was derived. Decoupled from PROV-O to prevent Entity coercion." .
# [Source 4] Links a specific perception to its generator.
rcao:hasSource rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range rcao:InformationSource ;
    rdfs:comment "Establishes the link of data from different sensors about perceptual awareness." .

# [Source 4] Link of unique Outcomes from different sensors.
rcao:hasOutcome rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range rcao:InformationSource ; 
    rdfs:comment "Establishes the link of unique Outcomes from different sensors." .

### http://www.example.org/rcao#wasComputedBy
rcao:wasComputedBy rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range prov:Activity ;
    rdfs:comment "A customized provenance property. Links a computed AwarenessState to the specific computational Activity (e.g., PerceptionProcess, FusionProcess) that generated it, bypassing strict PROV-O Entity coercion." .

### 2.3 Action Relationships

# [Source 3] Causal link indicating maneuver is caused from awareness state.
rcao:justifiedBy rdf:type owl:ObjectProperty ;
    rdfs:domain ago:Action ;
    rdfs:range rcao:AwarenessState ;
    rdfs:comment "Causal link to indicate maneuver is caused from awareness state level X." .

# [Source 3] Links an action to the object that is performing it.
ago:subjectOfAction rdf:type owl:ObjectProperty ;
    rdfs:domain ago:Action ;
    rdfs:range ago:Object ;
    rdfs:comment "Links an action to the object that is performing it." .

# [Source 3] Links an action to the object that is being acted upon.
ago:objectOfAction rdf:type owl:ObjectProperty ;
    rdfs:domain ago:Action ;
    rdfs:range ago:Object ;
    rdfs:comment "Links an action to the object that is being acted upon." .

### 2.4 Resilience & Quality Relations

# [Source 2] Associates an awareness state with its quality and trust metrics.
rcao:hasResilience rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range rcao:ResilienceAttribute ;
    rdfs:comment "Associates an awareness state with its quality and trust metrics." .

# [Source 5] Link of the trust of the value.
rcao:hasTrustScore rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ResilienceAttribute ;
    rdfs:range xsd:float ;
    rdfs:comment "A link of the trust of the value." .

# [Source 20] Links sensor to static resilience (e.g., Visibility Map).
rcao:hasSourceResilience rdf:type owl:ObjectProperty ;
    rdfs:domain rcao:InformationSource ;
    rdfs:range rcao:ResilienceAttribute .

# [Source 20] Links to gender bias score 
rcao:hasGenderBiasScore rdf:type owl:DatatypeProperty ;
                        rdfs:domain rcao:GenderBias ;
                        rdfs:range xsd:float ;
                        rdfs:comment "Quantifiable metric representing the severity of the gender bias." .


#################################################################
#    3. DATA PROPERTIES (Connected Vehicle & Others)
#################################################################

# [Source 3, 4] ConnectedVehicle Data Attributes
# Note: Source lists 'TrafficParticipant' as target, implying Domain=ConnectedVehicle, Range=Literal about Participant.

rcao:hasSpeed rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ConnectedVehicle ;
    rdfs:range xsd:float ;
    rdfs:comment "Speed of the participant." .

rcao:hasHeading rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ConnectedVehicle ;
    rdfs:range xsd:float ;
    rdfs:comment "Heading of the participant." .

rcao:hasDetectionConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ConnectedVehicle ;
    rdfs:range xsd:float ;
    rdfs:comment "Confidence level of the detection." .

rcao:hasEventType rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ConnectedVehicle ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of event detected." .

rcao:hasBrakeStatus rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:ConnectedVehicle ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Status of the brakes (Active/Inactive)." .

rcao:hasTimestamp rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime ;
    rdfs:comment "The time at which the data was generated or observed." .

# [Source 12] Standard Confidence
rcao:hasConfidence rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range xsd:float .



#################################################################
#    4.Physical MEREOLOGY and SPATIAL TOPOLOGY
#################################################################

schema:isPartOf rdf:type owl:ObjectProperty , owl:TransitiveProperty .
schema:hasPart rdf:type owl:ObjectProperty , owl:TransitiveProperty .
ago:hasPart rdfs:subPropertyOf schema:hasPart .

ago:isIn rdf:type owl:ObjectProperty ;
    rdfs:domain ago:Object ;
    rdfs:range ago:Object ;
    rdfs:comment "Denots spatial and positional relation of an object within another." .
#################################################################
#    HIERARCHY 7: COGNITIVE PROCESSES & ACTIVITIES (PROV-O Alignment)
#    Missing link required by Scenarios 1, 2, 3, 4
#################################################################

### SUPER: prov:Activity (Imported from PROV-O)

### MID: PerceptionProcess (Level 1 Generation)
rcao:PerceptionProcess rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "The activity of converting raw sensor data (Lidar, Camera, Eyes) into a structured PerceptualAwareness state (Level 1 SA). Executed by an Agent." .

### MID: ComprehensionProcess (Level 2 Generation)
rcao:ComprehensionProcess rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "The activity of synthesizing multiple PerceptualAwareness states and Context to infer meaning or risk (ComprehensionAwareness). Represents the 'Understanding' phase." .

### MID: BroadcastActivity (V2X Transmission)
rcao:BroadcastActivity rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "The specific activity of encoding and transmitting awareness states via V2X messages (CPM, DENM) to other agents." .

### MID: ODD_MonitoringProcess (Resilience/Safety)
rcao:ODD_MonitoringProcess rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "The activity of monitoring the Operational Design Domain (ODD) limits to trigger fallbacks if boundaries are exceeded (Scenario 7)." .

### NEW CLASS: Fusion Process (For Step 1 aggregation)
rcao:FusionProcess rdf:type owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:comment "A specific process that aggregates multiple AwarenessStates into a single intermediate fused state (PA_Fused)." .

### NEW PROPERTY: Fusion Strategy (For Step 2 output)
rcao:hasFusionStrategy rdf:type owl:DatatypeProperty ;
    rdfs:domain rcao:AwarenessState ;
    rdfs:range xsd:string ;
    rdfs:comment "Describes the logic strategy used by the RCA_Algo (e.g., 'agreement_consolidation')." .

### NEW PROPERTY: Explicit Fusion Inputs
rcao:fusesState rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:domain prov:Activity ; # Applies to FusionProcess OR ComprehensionProcess
    rdfs:range rcao:AwarenessState ;
    rdfs:comment "Explicitly links the process to the specific intermediate states it consumed. Identifies specific awareness states consumed during a fusion or comprehension process." .

### NEW PROPERTY: V2X Containment
# Aligned with schema:hasPart to denote that the AwarenessState is a constituent part of the Message.

rcao:contains rdf:type owl:ObjectProperty ;
    rdfs:subPropertyOf schema:hasPart ;  # <--- Alignment with Established Ontology
    rdfs:domain rcao:V2XMessage ;
    rdfs:range rcao:AwarenessState ;
    rdfs:comment "Links a V2X message (Container) to the AwarenessState (Content) it carries." .