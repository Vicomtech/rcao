@prefix : <http://www.example.org/rcao#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ago: <http://vcd.vicomtech.org/ontology/automotive#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix rcao: <http://www.example.org/rcao#> .
@prefix ex: <http://www.example.org/instances#> .

#################################################################
#    ELEMENTS OF THE SCENE
#################################################################

ex:EgoVehicle1 rdf:type ago:Vehicle ;
               ago:hasPart ex:ADS1 , ex:LIDAR1 .

ex:ADS1 rdf:type rcao:Algorithm ;
        ago:hasPart ex:RCA_Algo ;
        rdfs:comment "Automated Driving System" .

ex:RCA_Algo rdf:type rcao:Algorithm ;
            rdfs:comment "Resilient Collective Awareness Algorithm" .

ex:RSU1 rdf:type rcao:RoadSideUnit ;
        ago:hasPart ex:Camera1 .

ex:Camera1 rdf:type rcao:InformationSource .

ex:LIDAR1 rdf:type rcao:InformationSource .

ex:Pedestrian1 rdf:type ago:Pedestrian .

#################################################################
#    INITIAL SITUATION
#################################################################

ex:DrivingAutonomously1 rdf:type ago:Action ;
                        prov:wasAssociatedWith ex:ADS1 .

#################################################################
#    PERCEPTION PROCESS (RSU)
#################################################################

ex:PerceptionProcess1 rdf:type rcao:PerceptionProcess ;
                      prov:used ex:Camera1 ;
                      prov:wasAssociatedWith ex:RSU1 .

#################################################################
#    RESULT OF PERCEPTION PROCESS
#################################################################

ex:PA1_RSU1_of_P1 rdf:type rcao:PerceptualAwareness ;
                  rcao:hasSubject ex:RSU1 ;
                  rcao:isAwarenessOf ex:Pedestrian1 ;
                  rcao:derivedFrom ex:Camera1 ;
                  rcao:hasTimestamp "2026-02-02T10:00:00Z"^^xsd:dateTime ;
                  rcao:hasConfidence "0.85"^^xsd:float ;
                  prov:wasGeneratedBy ex:PerceptionProcess1 .

ex:Camera1_Score rdf:type rcao:ResilienceAttribute .

ex:Camera1 rcao:hasSourceResilience ex:Camera1_Score .

#################################################################
#    RSU BROADCASTS ITS PERCEPTION
#################################################################

ex:BroadcastCPM1 rdf:type rcao:BroadcastActivity ;
                 prov:wasAssociatedWith ex:RSU1 ;
                 prov:generated ex:CPM1 .

ex:CPM1 rdf:type rcao:V2XMessage ;
        rcao:encapsulates ex:PA1_RSU1_of_P1 .

#################################################################
#    COMPREHENSION PROCESS (ADS)
#################################################################

ex:ComprehensionProcess1 rdf:type rcao:ComprehensionProcess ;
                         prov:used ex:CPM1 ;
                         prov:wasAssociatedWith ex:ADS1 .

ex:Risk_Collision_Pedestrian1 rdf:type rcao:Risk .

ex:CA1_ADS1_of_RCP1 rdf:type rcao:ComprehensionAwareness ;
                    rcao:hasSubject ex:RCA_Algo ;
                    rcao:isAwarenessOf ex:Risk_Collision_Pedestrian1 ;
                    rcao:derivedFrom ex:PA1_RSU1_of_P1 ;
                    rdfs:comment "Camera in RSU ahead detected a pedestrian; the confidence of the perception process is good. According to the vehicle movement, there is risk of collision." ;
                    prov:wasGeneratedBy ex:ComprehensionProcess1 .

#################################################################
#    DECISION MAKING
#################################################################

ex:AdaptSpeed1 rdf:type ago:Action ;
               prov:wasAssociatedWith ex:ADS1 ;
               rcao:justifiedBy ex:CA1_ADS1_of_RCP1 .