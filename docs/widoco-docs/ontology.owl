<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/rcao#"
     xml:base="http://www.example.org/rcao"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:prov="http://www.w3.org/ns/prov#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://www.example.org/rcao">
        <owl:imports rdf:resource="http://vcd.vicomtech.org/ontology/automotive#"/>
        <owl:imports rdf:resource="http://www.w3.org/ns/prov-o#"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-02</terms:created>
        <terms:creator rdf:resource="https://orcid.org/0000-0000-0000-0000"/>
        <terms:description>Resilient Collective Awareness Ontology (RCAO) extension aligned with AGO and PROV-O.</terms:description>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-02-02</terms:modified>
        <terms:publisher rdf:resource="https://example.org/publisher"/>
        <terms:title>Resilient Collective Awareness Ontology</terms:title>
        <rdfs:comment>Resilient Collective Awareness Ontology (RCAO) extension aligned with AGO and PROV-O.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/created -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/modified -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/modified"/>
    


    <!-- http://purl.org/dc/terms/publisher -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/publisher"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/rcao#derivedFrom -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#derivedFrom">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasDerivedFrom"/>
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.example.org/rcao#AwarenessState"/>
                    <rdf:Description rdf:about="http://www.example.org/rcao#InformationSource"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>Links an awareness state to the source or previous state from which it was derived.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#encapsulates -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#encapsulates">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#V2XMessage"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Links a V2X message to the AwarenessState(s) it carries.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#fusesState -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#fusesState">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="http://www.example.org/rcao#FusionProcess"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Explicitly identifies which awareness states were consumed during the fusion process.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#hasAwarenessState -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#hasAwarenessState">
        <owl:inverseOf rdf:resource="http://www.example.org/rcao#hasSubject"/>
        <rdfs:domain rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Links a subject (an agent-like object) to a state of awareness it possesses.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#hasResilience -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#hasResilience">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:comment>Associates an awareness state with its quality and trust metrics.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#hasSourceResilience -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#hasSourceResilience">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#InformationSource"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:comment>Links a sensor/source to intrinsic quality attributes (e.g., occlusion map) independent of specific measurements.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#hasSubject -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#hasSubject">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:comment>Identifies the agent holding the awareness state.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#informs -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#informs">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Models the flow of information from perception to comprehension.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#isAwarenessOf -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#isAwarenessOf">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>Links an awareness state to the entity (Object, Action, or Context) it is about.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#justifiedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#justifiedBy">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasInfluencedBy"/>
        <rdfs:domain rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Action"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Indicates the AwarenessState that provided the reason for an Action.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#outputsTo -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#outputsTo">
        <rdfs:domain rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Action"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#HumanMachineInterface"/>
        <rdfs:comment>Indicates the device where an action displays information.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#runsProcess -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#runsProcess">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#wasAssociatedWith"/>
        <owl:inverseOf rdf:resource="http://www.w3.org/ns/prov#wasAssociatedWith"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment>Links the ADS or Algorithm to the computational process it is executing.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/rcao#usesSource -->


    <owl:ObjectProperty rdf:about="http://www.example.org/rcao#usesSource">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/ns/prov#used"/>
        <rdfs:domain rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:range rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Indicates that an action/process utilized a specific awareness state.</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/rcao#hasConfidence -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/rcao#hasConfidence">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>A confidence score (0.0 to 1.0) directly associated with the perception.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/rcao#hasFusionStrategy -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/rcao#hasFusionStrategy">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes the logic used to fuse data (e.g., &apos;agreement_consolidation&apos;, &apos;weighted_average&apos;).</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/rcao#hasTimestamp -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/rcao#hasTimestamp">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>The time at which the data was generated or observed.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/rcao#hasTrustScore -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/rcao#hasTrustScore">
        <rdfs:domain rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment>A quantifiable trust score for an information source.</rdfs:comment>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vcd.vicomtech.org/ontology/automotive#Action -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#Action"/>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#Context -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#Context"/>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#Human -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#Human">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment>A human traffic participant (Driver, VRU) capable of perception and action.</rdfs:comment>
    </owl:Class>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#Infrastructure -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#Infrastructure">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:comment>Static physical elements of the road environment.</rdfs:comment>
    </owl:Class>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#Object -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#Object"/>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#RoadMarking -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#RoadMarking">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement"/>
        <rdfs:comment>Painted indications on the road surface.</rdfs:comment>
    </owl:Class>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Infrastructure"/>
        <rdfs:comment>Regulatory objects governing traffic flow.</rdfs:comment>
    </owl:Class>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#TrafficSign -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#TrafficSign">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement"/>
        <rdfs:comment>Vertical signage (e.g., Speed Limit signs).</rdfs:comment>
    </owl:Class>
    


    <!-- http://vcd.vicomtech.org/ontology/automotive#TrafficSignal -->


    <owl:Class rdf:about="http://vcd.vicomtech.org/ontology/automotive#TrafficSignal">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#TrafficControlElement"/>
        <rdfs:comment>Active signaling devices (e.g., Traffic Lights).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#Algorithm -->


    <owl:Class rdf:about="http://www.example.org/rcao#Algorithm">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment>Computational agents (Fusion, Path Planning) acting as subjects within the traffic ontology.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#AutomatedDrivingSystem -->


    <owl:Class rdf:about="http://www.example.org/rcao#AutomatedDrivingSystem">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment>Represents the ADS agent.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#AwarenessState -->


    <owl:Class rdf:about="http://www.example.org/rcao#AwarenessState">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:comment>A reification of the awareness relationship.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#BroadcastActivity -->


    <owl:Class rdf:about="http://www.example.org/rcao#BroadcastActivity">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment>The process of encoding and transmitting awareness states via V2X.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#Completeness -->


    <owl:Class rdf:about="http://www.example.org/rcao#Completeness">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:comment>Measure of information completeness (e.g., Visibility/Occlusion Maps).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#ComprehensionAwareness -->


    <owl:Class rdf:about="http://www.example.org/rcao#ComprehensionAwareness">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <owl:disjointWith rdf:resource="http://www.example.org/rcao#PerceptualAwareness"/>
        <rdfs:comment>Level 2 SA: Understanding of significance/meaning.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#ComprehensionProcess -->


    <owl:Class rdf:about="http://www.example.org/rcao#ComprehensionProcess">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment>The activity of synthesizing PerceptualAwareness into ComprehensionAwareness (Level 2 SA).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#Driver -->


    <owl:Class rdf:about="http://www.example.org/rcao#Driver">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Human"/>
        <rdfs:comment>Represents the human operator whose awareness is critical.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#FusionProcess -->


    <owl:Class rdf:about="http://www.example.org/rcao#FusionProcess">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment>A computational process that aggregates multiple AwarenessState instances into a single fused state.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#HumanMachineInterface -->


    <owl:Class rdf:about="http://www.example.org/rcao#HumanMachineInterface">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#InformationSource"/>
        <rdfs:comment>A device (dashboard) that acts as an information source for human agents.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#InformationSource -->


    <owl:Class rdf:about="http://www.example.org/rcao#InformationSource">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment>Hardware or software generating data (Sensors, V2X, Algorithms).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#PerceptionProcess -->


    <owl:Class rdf:about="http://www.example.org/rcao#PerceptionProcess">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Activity"/>
        <rdfs:comment>The activity of converting raw sensor data into PerceptualAwareness (Level 1 SA).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#PerceptualAwareness -->


    <owl:Class rdf:about="http://www.example.org/rcao#PerceptualAwareness">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Level 1 SA: Direct perception of objects.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#PositionalAccuracy -->


    <owl:Class rdf:about="http://www.example.org/rcao#PositionalAccuracy">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:comment>Quantifies uncertainty in location (e.g., Covariance Matrix).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#ProjectionAwareness -->


    <owl:Class rdf:about="http://www.example.org/rcao#ProjectionAwareness">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#AwarenessState"/>
        <rdfs:comment>Level 3 SA: Prediction of future states.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#ResilienceAttribute -->


    <owl:Class rdf:about="http://www.example.org/rcao#ResilienceAttribute">
        <rdfs:comment>Qualitative attributes describing robustness or trust.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#Risk -->


    <owl:Class rdf:about="http://www.example.org/rcao#Risk">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Context"/>
        <rdfs:comment>A formalized assessment of potential danger (Context).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#RoadSideUnit -->


    <owl:Class rdf:about="http://www.example.org/rcao#RoadSideUnit">
        <rdfs:subClassOf rdf:resource="http://vcd.vicomtech.org/ontology/automotive#Object"/>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment>Intelligent infrastructure capable of perception and V2X communication (RSU).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#TemporalFreshness -->


    <owl:Class rdf:about="http://www.example.org/rcao#TemporalFreshness">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#ResilienceAttribute"/>
        <rdfs:comment>Captures data age/latency to prevent usage of stale information.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#V2XMessage -->


    <owl:Class rdf:about="http://www.example.org/rcao#V2XMessage">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:comment>A digital artifact transmitted between agents containing awareness states (e.g., ETSI CPM).</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.example.org/rcao#VirtualSensorAlgorithm -->


    <owl:Class rdf:about="http://www.example.org/rcao#VirtualSensorAlgorithm">
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#Algorithm"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/rcao#InformationSource"/>
        <rdfs:comment>An algorithm that acts as a traceable source of information (Virtual Sensor), effectively bridging prov:Agent and prov:Entity.</rdfs:comment>
    </owl:Class>
</rdf:RDF>



