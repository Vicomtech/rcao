  "@id" : "http://www.example.org/rcao#ComprehensionProcess",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The activity of synthesizing PerceptualAwareness into ComprehensionAwareness (Level 2 SA)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#Driver",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
