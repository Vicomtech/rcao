  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#ProjectionAwareness",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Level 3 SA: Prediction of future states."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#ResilienceAttribute",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Qualitative attributes describing robustness or trust."
  } ]
}, {
  "@id" : "http://www.example.org/rcao#Risk",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A formalized assessment of potential danger (Context)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Context"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#RoadSideUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Intelligent infrastructure capable of perception and V2X communication (RSU)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Object"
  }, {
    "@id" : "http://www.w3.org/ns/prov#Agent"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#TemporalFreshness",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Captures data age/latency to prevent usage of stale information."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#V2XMessage",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A digital artifact transmitted between agents containing awareness states (e.g., ETSI CPM)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#VirtualSensorAlgorithm",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "An algorithm that acts as a traceable source of information (Virtual Sensor), effectively bridging prov:Agent and prov:Entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/rcao#Algorithm"
  }, {
    "@id" : "http://www.example.org/rcao#InformationSource"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#derivedFrom",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Links an awareness state to the source or previous state from which it was derived."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid1"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#wasDerivedFrom"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#encapsulates",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Links a V2X message to the AwarenessState(s) it carries."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#V2XMessage"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#fusesState",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Explicitly identifies which awareness states were consumed during the fusion process."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#FusionProcess"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#used"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasAwarenessState",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Links a subject (an agent-like object) to a state of awareness it possesses."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Object"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.example.org/rcao#hasSubject"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasConfidence",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A confidence score (0.0 to 1.0) directly associated with the perception."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#float"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasFusionStrategy",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Describes the logic used to fuse data (e.g., 'agreement_consolidation', 'weighted_average')."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#string"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasResilience",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Associates an awareness state with its quality and trust metrics."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasSourceResilience",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Links a sensor/source to intrinsic quality attributes (e.g., occlusion map) independent of specific measurements."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/rcao#InformationSource"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/rcao#ResilienceAttribute"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#hasSubject",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Identifies the agent holding the awareness state."
