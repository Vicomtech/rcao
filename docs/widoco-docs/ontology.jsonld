    "@id" : "http://vcd.vicomtech.org/ontology/automotive#Object"
  }, {
    "@id" : "http://www.example.org/rcao#InformationSource"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#InformationSource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Hardware or software generating data (Sensors, V2X, Algorithms)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#PerceptionProcess",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The activity of converting raw sensor data into PerceptualAwareness (Level 1 SA)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Activity"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#PerceptualAwareness",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Level 1 SA: Direct perception of objects."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/rcao#AwarenessState"
  } ]
}, {
  "@id" : "http://www.example.org/rcao#PositionalAccuracy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
